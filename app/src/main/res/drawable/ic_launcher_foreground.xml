<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:gravity="center"
        android:width="84dp"
        android:height="84dp">
        <shape android:shape="oval">
            <solid android:color="#26FFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="top|center_horizontal"
        android:top="22dp"
        android:width="26dp"
        android:height="26dp">
        <shape android:shape="oval">
            <solid android:color="@color/white" />
        </shape>
    </item>

    <item
        android:gravity="top|center_horizontal"
        android:top="22dp"
        android:left="10dp"
        android:width="20dp"
        android:height="20dp">
        <shape android:shape="oval">
            <solid android:color="@color/forest_dark" />
        </shape>
    </item>

    <item
        android:gravity="bottom|center_horizontal"
        android:bottom="24dp"
        android:width="56dp"
        android:height="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#F2FFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="bottom|left"
        android:left="26dp"
        android:bottom="24dp"
        android:width="10dp"
        android:height="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#CCFFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="bottom|right"
        android:right="26dp"
        android:bottom="24dp"
        android:width="10dp"
        android:height="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#CCFFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="bottom|center_horizontal"
        android:bottom="24dp"
        android:width="18dp"
        android:height="16dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="9dp"
                android:topRightRadius="9dp"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <solid android:color="#59065F46" />
        </shape>
    </item>
</layer-list>

